# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,https://admin.khalto.app,https://khalto.app

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=khalto
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_random_string
JWT_REFRESH_SECRET=another_random_32_chars_string
# Tokens expire in 7 days / refresh 30 days

# ── Firebase (Push Notifications) ────────────────────────
FIREBASE_PROJECT_ID=khalto-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@khalto-app.iam.gserviceaccount.com

# ── Twilio (SMS) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_SA=+966xxxxxxxxx
TWILIO_PHONE_EG=+20xxxxxxxxxx

# ── SendGrid (Email) ──────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@khalto.app

# ── AWS S3 / Cloudflare R2 (File Storage) ────────────────
S3_REGION=me-south-1
S3_BUCKET=khalto-uploads
S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_ENDPOINT=                           # Leave empty for AWS, set for R2
CDN_URL=https://khalto-uploads.s3.amazonaws.com

# ── Payment Gateways ──────────────────────────────────────
TAP_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAP_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_INTEGRATION_ID=xxxxxx
PAYMOB_HMAC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Maps ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Social Auth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxx.apps.googleusercontent.com
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX

# ── Finance ───────────────────────────────────────────────
FINANCE_BCC_EMAIL=finance@khalto.app

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── Additional Required Variables ──────────────────────────
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/khalto_dev
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
BLOCKED_IPS=
PAYMOB_IFRAME_ID=
SMTP_PASS=
TWILIO_PHONE_NUMBER=+966xxxxxxxxx
